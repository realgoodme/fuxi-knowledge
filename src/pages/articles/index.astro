---
import { getCollection } from "astro:content";
import ContentCard from "../../components/ContentCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles")).sort((a, b) => (b.data.publicOrder ?? 0) - (a.data.publicOrder ?? 0));
---

<BaseLayout title="文章｜朴散的思想仓库">
  <section class="listing-hero"><p class="eyebrow">ARCHIVE</p><h1>文章</h1><p>故事、观察，以及不急着下结论的思考。</p></section>
  <section class="section-wrap listing-grid"><div class="card-grid">{articles.map((entry) => <ContentCard entry={entry} />)}</div></section>
</BaseLayout>
