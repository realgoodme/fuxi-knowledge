---
import { getCollection } from "astro:content";
import ContentCard from "../../components/ContentCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticleTopicMap } from "../../utils/relations";

const articles = (await getCollection("articles")).sort((a, b) => (b.data.publicOrder ?? 0) - (a.data.publicOrder ?? 0));
const topicMap = await getArticleTopicMap();
const seriesOptions = [...new Set(articles.map((entry) => entry.data.series).filter(Boolean))];
const yearOptions = [...new Set(articles.map((entry) => (entry.data.date ?? entry.data.ingested)?.getFullYear()).filter(Boolean))].sort((a, b) => b - a);
---

<BaseLayout title="文章｜朴散的思想仓库">
  <section class="archive-hero">
    <p class="eyebrow">THE WRITING ARCHIVE</p>
    <div><h1>文章目录</h1><p>故事、观察，以及不急着下结论的思考。每一篇都是一个被留下来的现场。</p></div>
    <span>{String(articles.length).padStart(2, "0")} ENTRIES</span>
  </section>

  <section class="archive-toolbar" id="archive-search" aria-label="文章筛选">
    <label class="toolbar-search"><span>搜索</span><input data-search-input type="search" placeholder="标题 / 摘要 / 主题" /></label>
    <label><span>系列</span><select data-series-filter><option value="">全部</option>{seriesOptions.map((series) => <option value={series}>{series}</option>)}</select></label>
    <label><span>年份</span><select data-year-filter><option value="">全部</option>{yearOptions.map((year) => <option value={year}>{year}</option>)}</select></label>
    <button type="button" data-clear-filters>清空筛选</button>
  </section>

  <section class="archive-section archive-listing">
    <div class="card-grid">
      {articles.map((entry, index) => {
        const topic = topicMap.get(entry.id);
        const year = (entry.data.date ?? entry.data.ingested)?.getFullYear() ?? "";
        const searchText = `${entry.data.title} ${entry.data.summary ?? ""} ${entry.data.series ?? ""} ${topic?.title ?? ""}`;
        return (
          <div class="archive-item" data-search={searchText} data-series={entry.data.series ?? ""} data-year={year}>
            <ContentCard entry={entry} index={index + 1} topicTitle={topic?.title} />
          </div>
        );
      })}
    </div>
    <p class="archive-empty" data-archive-empty hidden>没有找到相关文章。试试减少筛选条件，或清空筛选。</p>
  </section>

  <script is:inline>
    const input = document.querySelector("[data-search-input]");
    const seriesFilter = document.querySelector("[data-series-filter]");
    const yearFilter = document.querySelector("[data-year-filter]");
    const clearButton = document.querySelector("[data-clear-filters]");
    const items = [...document.querySelectorAll(".archive-item")];
    const empty = document.querySelector("[data-archive-empty]");
    const applyFilters = () => {
      const query = (input?.value ?? "").trim().toLowerCase();
      const series = seriesFilter?.value ?? "";
      const year = yearFilter?.value ?? "";
      let visible = 0;
      for (const item of items) {
        const show = (!query || item.dataset.search.toLowerCase().includes(query)) && (!series || item.dataset.series === series) && (!year || item.dataset.year === String(year));
        item.style.display = show ? "" : "none";
        if (show) visible += 1;
      }
      if (empty) empty.hidden = visible !== 0;
    };
    [input, seriesFilter, yearFilter].forEach((control) => control?.addEventListener("input", applyFilters));
    clearButton?.addEventListener("click", () => { if (input) input.value = ""; if (seriesFilter) seriesFilter.value = ""; if (yearFilter) yearFilter.value = ""; applyFilters(); });
  </script>
</BaseLayout>
