---
import { getCollection } from "astro:content";
import ContentCard from "../../components/ContentCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = (await getCollection("articles")).sort((a, b) => (b.data.publicOrder ?? 0) - (a.data.publicOrder ?? 0));
---

<BaseLayout title="文章｜朴散的思想仓库">
  <section class="archive-hero">
    <p class="eyebrow">THE WRITING ARCHIVE</p>
    <div><h1>文章目录</h1><p>故事、观察，以及不急着下结论的思考。每一篇都是一个被留下来的现场。</p></div>
    <span>{String(articles.length).padStart(2, "0")} ENTRIES</span>
  </section>
  <section class="archive-section archive-listing"><div class="card-grid">{articles.map((entry, index) => <ContentCard entry={entry} index={index + 1} />)}</div></section>
</BaseLayout>
