---
import { getCollection } from "astro:content";
import ContentCard from "../components/ContentCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArticleTopicMap, getTopicRelations } from "../utils/relations";

const base = import.meta.env.BASE_URL;
const byOrder = (a, b) => (b.data.publicOrder ?? 0) - (a.data.publicOrder ?? 0);
const articles = (await getCollection("articles")).sort(byOrder);
const topics = (await getCollection("topics")).sort(byOrder);
const featured = articles[0];
const recent = articles.slice(1, 4);
const topicMap = await getArticleTopicMap();
const relations = await getTopicRelations();
const relationMap = new Map(relations.map((relation) => [relation.id, relation]));
const articleById = new Map(articles.map((entry) => [entry.id, entry]));
const threadTopics = relations.filter((relation) => relation.count > 0).slice(0, 3);
const latestTopic = topics[0];
const featuredTopic = featured ? topicMap.get(featured.id) : undefined;
---

<BaseLayout>
  <section class="home-hero">
    <div class="hero-ledger">
      <span>写作档案 / 2026</span>
      <span>PUBLIC EDITION · {String(articles.length).padStart(2, "0")}</span>
    </div>
    <div class="hero-grid">
      <div class="hero-title-wrap">
        <p class="eyebrow">PUSANZ · WRITING ARCHIVE</p>
        <h1>把观察写下来，<br /><em>让经验留下来。</em></h1>
        <p class="hero-copy">警察、写作者、互联网产品人。这里存放故事、判断与长期实践，而不只是即时观点。</p>
        <div class="hero-actions" aria-label="首屏操作">
          {featured && <a class="button button-primary" href={`${base}articles/${featured.id}/`}>读最新一篇</a>}
          <a class="button button-secondary" href={`${base}topics/`}>浏览主题地图</a>
        </div>
      </div>
      <aside class="hero-clue" aria-label="本期线索">
        <h2>本期线索</h2>
        {featured && (
          <a class="clue-row" href={`${base}articles/${featured.id}/`}>
            <strong>最新文章：{featured.data.title}</strong>
            <span>{featuredTopic ? `所属主题：${featuredTopic.title}` : featured.data.series ?? "原创文章"}</span>
          </a>
        )}
        {latestTopic && (
          <a class="clue-row" href={`${base}topics/${latestTopic.id}/`}>
            <strong>最新修订：{latestTopic.data.title}</strong>
            <span>主题状态：{relationMap.get(latestTopic.id)?.status ?? "编织中"}</span>
          </a>
        )}
        <a class="clue-row" href={`${base}topics/daming-xunjiansi/`}>
          <strong>系列入口：大明巡检司</strong>
          <span>用古代巡检司的壳，装当代基层吏治的酒 →</span>
        </a>
      </aside>
    </div>
    <div class="hero-index" aria-label="公开内容统计">
      <a href={`${base}articles/`}><strong>{String(articles.length).padStart(2, "0")}</strong><span>篇原创文章</span></a>
      <a href={`${base}topics/`}><strong>{String(topics.length).padStart(2, "0")}</strong><span>个编织主题</span></a>
      <a href={`${base}articles/`}>进入档案目录 <b>↓</b></a>
    </div>
  </section>

  {featured && (
    <section class="featured-section">
      <div class="section-label"><span>01</span><p>本期主推 / FEATURED NOTE</p></div>
      <article class="featured-story">
        <div class="featured-number">{String(featured.data.publicOrder ?? articles.length).padStart(2, "0")}</div>
        <div>
          <p class="eyebrow">{featured.data.series ?? "原创文章"}</p>
          {featuredTopic && <p class="featured-topic">所属主题：{featuredTopic.title}</p>}
          <h2><a href={`${base}articles/${featured.id}/`}>{featured.data.title}</a></h2>
          <p>{featured.data.summary}</p>
          <a class="text-link" href={`${base}articles/${featured.id}/`}>打开这篇文章 <span>→</span></a>
          {featuredTopic && <a class="text-link" href={`${base}topics/${featuredTopic.id}/`}>查看所属主题 <span>→</span></a>}
        </div>
      </article>
    </section>
  )}

  <section class="archive-section">
    <div class="section-heading">
      <div><p class="eyebrow">LATEST ENTRIES</p><h2>最新归档</h2></div>
      <a class="text-link" href={`${base}articles/`}>查看全部 <span>→</span></a>
    </div>
    <div class="card-grid">{recent.map((entry, index) => <ContentCard entry={entry} index={index + 1} topicTitle={topicMap.get(entry.id)?.title} />)}</div>
  </section>

  <section class="theme-section">
    <div class="theme-head">
      <p class="eyebrow">THOUGHT MAP</p>
      <h2>不是堆叠文章，<br />而是把它们<em>织回主题。</em></h2>
      <p>主题页记录暂时成立的结论、证据与反例；它们会随新的写作继续修订。</p>
      <div class="theme-thread" aria-label="主题织线示例">
        {threadTopics.map((relation) => (
          <div class="thread-line">
            <a class="thread-topic" href={`${base}topics/${relation.id}/`}>{relation.title}</a>
            <span>├─</span>
            <a href={`${base}articles/${relation.articleIds[0]}/`}>{articleById.get(relation.articleIds[0])?.data.title ?? relation.articleIds[0]}</a>
          </div>
        ))}
      </div>
      <a class="text-link" href={`${base}topics/`}>浏览主题地图 <span>→</span></a>
    </div>
    <div class="theme-list">{topics.slice(0, 4).map((entry, index) => <ContentCard entry={entry} kind="topic" index={index + 1} topicCount={relationMap.get(entry.id)?.count} topicStatus={relationMap.get(entry.id)?.status} />)}</div>
  </section>

  <section class="about-panel" id="about">
    <p class="eyebrow">ABOUT THE ARCHIVE</p>
    <div><h2>写作不是输出，<br />是留下可回看的证据。</h2><p>完整知识库只在本地维护；这里仅公开原创文章与已沉淀成形的主题。每一次公开，都是一次对经验的重新整理。</p></div>
  </section>
</BaseLayout>
