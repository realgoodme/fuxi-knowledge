---
import { getCollection } from "astro:content";
import ContentCard from "../components/ContentCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const byOrder = (a, b) => (b.data.publicOrder ?? 0) - (a.data.publicOrder ?? 0);
const articles = (await getCollection("articles")).sort(byOrder);
const topics = (await getCollection("topics")).sort(byOrder);
const featured = articles[0];
const recent = articles.slice(1, 4);
---

<BaseLayout>
  <section class="home-hero">
    <div class="hero-ledger">
      <span>写作档案 / 2026</span>
      <span>PUBLIC EDITION · {String(articles.length).padStart(2, "0")}</span>
    </div>
    <div class="hero-title-wrap">
      <p class="eyebrow">PUSANZ · WRITING ARCHIVE</p>
      <h1>把观察写下来，<br /><em>让经验留下来。</em></h1>
      <p class="hero-copy">警察、写作者、互联网产品人。这里存放故事、判断与长期实践，而不只是即时观点。</p>
    </div>
    <div class="hero-index" aria-label="公开内容统计">
      <div><strong>{String(articles.length).padStart(2, "0")}</strong><span>篇原创文章</span></div>
      <div><strong>{String(topics.length).padStart(2, "0")}</strong><span>个编织主题</span></div>
      <a href={`${base}articles/`}>进入档案目录 <b>↓</b></a>
    </div>
  </section>

  {featured && (
    <section class="featured-section">
      <div class="section-label"><span>01</span><p>本期主推 / FEATURED NOTE</p></div>
      <article class="featured-story">
        <div class="featured-number">{String(featured.data.publicOrder ?? articles.length).padStart(2, "0")}</div>
        <div>
          <p class="eyebrow">{featured.data.series ?? "原创文章"}</p>
          <h2><a href={`${base}articles/${featured.id}/`}>{featured.data.title}</a></h2>
          <p>{featured.data.summary}</p>
          <a class="text-link" href={`${base}articles/${featured.id}/`}>打开这篇文章 <span>→</span></a>
        </div>
      </article>
    </section>
  )}

  <section class="archive-section">
    <div class="section-heading">
      <div><p class="eyebrow">LATEST ENTRIES</p><h2>最新归档</h2></div>
      <a class="text-link" href={`${base}articles/`}>查看全部 <span>→</span></a>
    </div>
    <div class="card-grid">{recent.map((entry, index) => <ContentCard entry={entry} index={index + 1} />)}</div>
  </section>

  <section class="theme-section">
    <div class="theme-head">
      <p class="eyebrow">THOUGHT MAP</p>
      <h2>不是堆叠文章，<br />而是把它们<em>织回主题。</em></h2>
      <p>主题页记录暂时成立的结论、证据与反例；它们会随新的写作继续修订。</p>
      <a class="text-link" href={`${base}topics/`}>浏览主题地图 <span>→</span></a>
    </div>
    <div class="theme-list">{topics.slice(0, 4).map((entry, index) => <ContentCard entry={entry} kind="topic" index={index + 1} />)}</div>
  </section>

  <section class="about-panel" id="about">
    <p class="eyebrow">ABOUT THE ARCHIVE</p>
    <div><h2>写作不是输出，<br />是留下可回看的证据。</h2><p>完整知识库只在本地维护；这里仅公开原创文章与已沉淀成形的主题。每一次公开，都是一次对经验的重新整理。</p></div>
  </section>
</BaseLayout>
