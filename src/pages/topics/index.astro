---
import { getCollection } from "astro:content";
import ContentCard from "../../components/ContentCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const topics = (await getCollection("topics")).sort((a, b) => (b.data.publicOrder ?? 0) - (a.data.publicOrder ?? 0));
---

<BaseLayout title="专题｜朴散的思想仓库">
  <section class="listing-hero"><p class="eyebrow">TOPICS</p><h1>专题</h1><p>把零散文章往回织，留下可以反复使用的判断。</p></section>
  <section class="section-wrap listing-grid"><div class="card-grid">{topics.map((entry) => <ContentCard entry={entry} kind="topic" />)}</div></section>
</BaseLayout>
