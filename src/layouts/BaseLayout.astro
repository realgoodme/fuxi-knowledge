---
import "../styles/global.css";

const {
  title = "朴散的思想仓库",
  description = "一个警察写作者的观察、故事与 AI 实践。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="回到首页">朴散<span>·</span>思想仓库</a>
      <nav aria-label="主导航">
        <a href="/articles/">文章</a>
        <a href="/topics/">专题</a>
        <a href="/#about">关于</a>
      </nav>
    </header>
    <main><slot /></main>
    <footer>
      <span>边写 · 边存 · 边进化</span>
      <span>© 2026 朴散</span>
    </footer>
  </body>
</html>
